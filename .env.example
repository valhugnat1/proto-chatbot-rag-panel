# --- Mistral ---------------------------------------------------------------
# Required. Get one at https://console.mistral.ai/
MISTRAL_API_KEY=changeme

# Optional overrides
MISTRAL_MODEL=mistral-large-latest
MISTRAL_EMBED_MODEL=mistral-embed

# --- Database --------------------------------------------------------------
# Inside docker-compose, the host is `db`. For running the backend on the
# host directly, use `localhost`.
DATABASE_URL=postgresql+psycopg://bnp:bnp@db:5432/bnp

# --- CORS / Frontend -------------------------------------------------------
FRONTEND_URL=http://localhost:5173

# Backend URL baked into the frontend build. From the browser's POV, this
# is the host-published backend port (always localhost in local dev).
VITE_API_URL=http://localhost:8000

# --- Misc ------------------------------------------------------------------
LOG_LEVEL=INFO
