# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/

# Env / secrets
.env
.env.local

# Scrape cache (regenerable)
backend/app/data/scraped/*.jsonl

# IDE
.vscode/
